# Database settings for docker-compose.yml
DB_NAME=postgres_db
DB_USER=postgres
DB_PASSWORD=postgres

JWT_SECRET_BASE64=MDEyMzQ1Njc4OUFCQ0RFRjAxMjM0NTY3ODlBQkNERUY=
JWT_ISSUER=coactivity-core
JWT_AUDIENCE=coactivity-api
JWT_EXPIRATION_MINUTES=30

# Local core run mode (docker-compose forces SERVICE mode in core-service container)
QA_MODE=MONOLITH
QA_SERVICE_BASE_URL=http://localhost:8081

# Kafka between core-service and notifications-service
NOTIFICATIONS_KAFKA_TOPIC=notifications.email.v1
NOTIFICATIONS_KAFKA_SEND_TIMEOUT_MS=5000
NOTIFICATIONS_KAFKA_GROUP_ID=notifications-service-v1
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# SMTP settings for notifications-service only
# Local docker-compose uses Mailpit by default.
# Do not store a real Gmail app password in this file.
# For a real Gmail smoke test, prefer one-off shell exports or ./scripts/gmail-smoke-test.sh
SPRING_MAIL_HOST=mailpit
SPRING_MAIL_PORT=1025
SPRING_MAIL_SMTP_AUTH=false
SPRING_MAIL_SMTP_STARTTLS_ENABLE=false
SPRING_MAIL_SMTP_STARTTLS_REQUIRED=false
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# For real Gmail, override the values above, for example:
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
# SPRING_MAIL_SMTP_STARTTLS_REQUIRED=true
# SPRING_MAIL_USERNAME=your@gmail.com
# SPRING_MAIL_PASSWORD=your-app-password
