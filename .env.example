# CORS for browser clients (core-service). Comma-separated origins or patterns (e.g. http://localhost:* for any Vite port).
APP_CORS_ALLOWED_ORIGINS=http://localhost:*

# Database settings for docker-compose.yml
DB_NAME=postgres_db
DB_USER=postgres
DB_PASSWORD=postgres

# Required: generate your own Base64 secret, for example with:
# openssl rand -base64 32
JWT_SECRET_BASE64=
JWT_ISSUER=coactivity-core
JWT_AUDIENCE=coactivity-api
JWT_EXPIRATION_MINUTES=30

# Internal HTTP address of qa-service for docker-compose runtime.
# If you run core-service locally, override this with http://localhost:8081.
QA_SERVICE_BASE_URL=http://qa-service:8081

# Local core-service without working Kafka: login still sends 202 and logs the OTP at WARN (see AuthService).
AUTH_LOGIN_ALLOW_WITHOUT_KAFKA=false

# Kafka between core-service and notifications-service
NOTIFICATIONS_KAFKA_TOPIC=notifications.email.v1
NOTIFICATIONS_KAFKA_SEND_TIMEOUT_MS=5000
NOTIFICATIONS_KAFKA_GROUP_ID=notifications-service-v1
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# SMTP — required for login verification emails (core -> Kafka -> notifications-service -> SMTP).
# Without SPRING_MAIL_USERNAME / SPRING_MAIL_PASSWORD the code is published to Kafka but mail is never sent.
# The project uses Yandex SMTP by default. Use a Yandex app password, not the main account password.
SPRING_MAIL_HOST=smtp.yandex.ru
SPRING_MAIL_PORT=587
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_SMTP_STARTTLS_REQUIRED=true
SPRING_MAIL_USERNAME=your-mail@yandex.ru
SPRING_MAIL_PASSWORD=your-app-password
