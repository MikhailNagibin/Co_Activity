# Local/dev settings for docker-compose.yml
# For Yandex SMTP with docker-compose.prod.yml use .env.prod.example instead.
DB_NAME=postgres_db
DB_USER=postgres
DB_PASSWORD=postgres

# Redis for Spring Session.
# Docker Compose in this repo starts Redis without auth, so password is not needed there.
# Set SPRING_DATA_REDIS_PASSWORD only if you run against your own password-protected Redis.
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# Session cookie policy
# local/dev is HTTP on localhost, so Secure must be false or browser will drop the cookie.
SESSION_COOKIE_SECURE=false

# Kafka between core-service and notifications-service
# In production these topics must be created by infrastructure or a dedicated bootstrap job
# before core-service and notifications-service start.
NOTIFICATIONS_KAFKA_TOPIC=notifications.email.v1
NOTIFICATIONS_KAFKA_DLT_TOPIC=
NOTIFICATIONS_KAFKA_PARTITIONS=1
NOTIFICATIONS_KAFKA_REPLICATION_FACTOR=1
NOTIFICATIONS_KAFKA_SEND_TIMEOUT_MS=5000
NOTIFICATIONS_KAFKA_GROUP_ID=notifications-service-v1
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:29092
SPRING_KAFKA_LISTENER_MISSING_TOPICS_FATAL=true

# notifications-service profile
# Use `local` for Mailpit during development and `prod` for a real SMTP provider like Yandex.
SPRING_PROFILES_ACTIVE=local

# SMTP settings for notifications-service in local development
# Mailpit from docker-compose is exposed to the host at localhost:1025 and web UI at http://localhost:8025.
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
SPRING_MAIL_SMTP_AUTH=false
SPRING_MAIL_SMTP_STARTTLS_ENABLE=false
SPRING_MAIL_SMTP_STARTTLS_REQUIRED=false
NOTIFICATIONS_MAIL_FROM=
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
MANAGEMENT_HEALTH_MAIL_ENABLED=true
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always
NOTIFICATIONS_HEALTH_KAFKA_TOPICS_TIMEOUT_MS=5000

# Production example for Yandex SMTP:
# SPRING_PROFILES_ACTIVE=prod
# SPRING_MAIL_HOST=smtp.yandex.ru
# SPRING_MAIL_PORT=587
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
# SPRING_MAIL_SMTP_STARTTLS_REQUIRED=true
# NOTIFICATIONS_MAIL_FROM=your-sender@yandex.ru
# SPRING_MAIL_USERNAME=your-login@yandex.ru
# SPRING_MAIL_PASSWORD=your-yandex-app-password
