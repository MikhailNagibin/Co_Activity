# Database settings for production-like docker-compose
DB_NAME=postgres_db
DB_USER=postgres
DB_PASSWORD=postgres

# Redis for Spring Session
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# Kafka between core-service and notifications-service
# In production these topics must be created by infrastructure or a dedicated bootstrap job
# before core-service and notifications-service start.
NOTIFICATIONS_KAFKA_TOPIC=notifications.email.v1
NOTIFICATIONS_KAFKA_DLT_TOPIC=
NOTIFICATIONS_KAFKA_PARTITIONS=1
NOTIFICATIONS_KAFKA_REPLICATION_FACTOR=1
NOTIFICATIONS_KAFKA_SEND_TIMEOUT_MS=5000
NOTIFICATIONS_KAFKA_GROUP_ID=notifications-service-v1
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:29092
SPRING_KAFKA_LISTENER_MISSING_TOPICS_FATAL=true

# notifications-service profile
SPRING_PROFILES_ACTIVE=prod

# SMTP settings for notifications-service in production
SPRING_MAIL_HOST=smtp.yandex.ru
SPRING_MAIL_PORT=587
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_SMTP_STARTTLS_REQUIRED=true
NOTIFICATIONS_MAIL_FROM=your-sender@yandex.ru
SPRING_MAIL_USERNAME=your-login@yandex.ru
SPRING_MAIL_PASSWORD=your-yandex-app-password

# Actuator / monitoring
MANAGEMENT_HEALTH_MAIL_ENABLED=true
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=never
NOTIFICATIONS_HEALTH_KAFKA_TOPICS_TIMEOUT_MS=5000

# Security
SESSION_COOKIE_SECURE=true
